<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SmartCare" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryVariant">@color/teal_primary_variant</item>
        <item name="colorOnPrimary">@color/white_clinical</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_secondary</item>
        <item name="colorSecondaryVariant">@color/teal_primary</item>
        <item name="colorOnSecondary">@color/white_clinical</item>

        <!-- Background and Surface colors. -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/white_clinical</item>

        <!-- Error color. -->
        <item name="colorError">@color/red_alert</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- General text colors. -->
        <item name="android:textColorPrimary">@color/text_dark</item>
        <item name="android:textColorSecondary">@color/text_gray</item>
    </style>
</resources>
